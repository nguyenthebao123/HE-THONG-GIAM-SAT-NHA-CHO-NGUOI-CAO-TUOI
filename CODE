// WIFI + TELEGRAM CONFIG
#define WIFI_SSID "Boo"
#define WIFI_PASS "06062005"

#define BOT_TOKEN "8319195557:AAEfj9tG1SaFNEsRyzLUZqsHyXX1iH1-50o"
#define CHAT_ID   "6032360121"

// PIN CONFIGURATION
#define MQ2_PIN        34
#define SERVO_PIN      27

// HC-SR04 ultrasonic sensor
#define TRIG_PIN       14
#define ECHO_PIN       12

#define PIR_ALERT_PIN  18
#define RD03_PIN       4
#define LED_PIN        15
#define BUZZER_PIN     13
#define CHECK_PIN      5

#define GAS_THRESHOLD 1500
#define DISTANCE_THRESHOLD 50

// TASK HANDLES
TaskHandle_t gasTaskHandle;
TaskHandle_t fallTaskHandle;
TaskHandle_t doorTaskHandle;
TaskHandle_t telegramTaskHandle;

// SERVO OBJECT
Servo myServo;

// SHARED VARIABLES AND MUTEX
SemaphoreHandle_t gasMutex;
volatile bool gasDetected = false;
volatile bool gasEmergency = false;
volatile bool manualClose = false;
volatile bool manualOpen = false;
unsigned long manualOpenTimer = 0;

// Variables for Motion Logic
volatile bool ledOn = false; 

// HC-SR04 DISTANCE MEASUREMENT FUNCTION
long getDistance() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);
  
  long duration = pulseIn(ECHO_PIN, HIGH, 30000);
  long distance = duration * 0.034 / 2;
  
  return distance;
}

// ISR: HÀM NGẮT BẬT ĐÈN
void IRAM_ATTR ISR_detectsMovement() {
  if (!gasEmergency) { 
    digitalWrite(LED_PIN, HIGH);
    ledOn = true;
  }
}

// TELEGRAM MESSAGE SENDING FUNCTION
void sendTelegram(const String &message) {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("WiFi chưa kết nối");
    return;
  }

  Serial.println("Đang gửi Telegram: " + message);

  WiFiClientSecure client;
  client.setInsecure();

  HTTPClient http;
  http.setTimeout(10000);

  String url = "https://api.telegram.org/bot";
  url += BOT_TOKEN;
  url += "/sendMessage";

  http.begin(client, url);
  http.addHeader("Content-Type", "application/x-www-form-urlencoded");

  String encodedMsg = message;
  encodedMsg.replace(" ", "%20");
  encodedMsg.replace(":", "%3A");
  encodedMsg.replace("/", "%2F");
  
  String postData = "chat_id=" + String(CHAT_ID) + "&text=" + encodedMsg;
  
  int httpCode = http.POST(postData);
  
  if (httpCode > 0) {
    Serial.printf("Telegram gửi thành công! HTTP Code: %d\n", httpCode);
  } else {
    Serial.printf("Lỗi gửi Telegram: %s\n", http.errorToString(httpCode).c_str());
  }
  
  http.end();
  client.stop();
  
  vTaskDelay(pdMS_TO_TICKS(1000));
}

// DECLARE TASKS
void gasTask(void *pvParameters);
void fallTask(void *pvParameters);
void doorTask(void *pvParameters);
void telegramTask(void *pvParameters);

// SETUP FUNCTION
void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n\nESP32 Smart Home Starting...");

  pinMode(PIR_ALERT_PIN, INPUT_PULLUP);
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  pinMode(RD03_PIN, INPUT);
  pinMode(CHECK_PIN, INPUT_PULLUP);
  pinMode(LED_PIN, OUTPUT);
  pinMode(BUZZER_PIN, OUTPUT);

  digitalWrite(BUZZER_PIN, LOW);
  digitalWrite(LED_PIN, LOW);
  digitalWrite(TRIG_PIN, LOW);

  attachInterrupt(digitalPinToInterrupt(PIR_ALERT_PIN), ISR_detectsMovement, RISING);

  myServo.attach(SERVO_PIN);
  myServo.write(0);
  Serial.println("Servo initialized");

  Serial.print("Connecting to WiFi");
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  
  int wifiRetry = 0;
  while (WiFi.status() != WL_CONNECTED && wifiRetry < 20) {
    delay(500);
    Serial.print(".");
    wifiRetry++;
  }
  
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\nWiFi connected!");
    sendTelegram("ESP32 started and WiFi connected");
  } else {
    Serial.println("\nWiFi connection failed!");
  }

  gasMutex = xSemaphoreCreateMutex();

  xTaskCreatePinnedToCore(gasTask,      "GAS",      8192, NULL, 4, &gasTaskHandle,      1);
  xTaskCreatePinnedToCore(fallTask,     "FALL",     8192, NULL, 3, &fallTaskHandle,     1);
  xTaskCreatePinnedToCore(doorTask,     "DOOR",     4096, NULL, 2, &doorTaskHandle,     1);
  xTaskCreatePinnedToCore(telegramTask, "TELEGRAM", 8192, NULL, 1, &telegramTaskHandle, 0);

  Serial.println("All tasks started!");
}

void loop() {}

// TASK 1: GAS DETECTION
void gasTask(void *pvParameters) {
  bool gasSent = false;
  int gasCount = 0, clearCount = 0;

  Serial.println("TASK GAS: Running (Master Priority)");

  while (1) {
    int adc = analogRead(MQ2_PIN);
    
    if (adc > GAS_THRESHOLD) {
      gasCount++;
      clearCount = 0;
      if (gasCount % 5 == 0) Serial.printf("Gas detected! Level: %d\n", adc);
    } else {
      clearCount++;
      gasCount = 0;
    }

    xSemaphoreTake(gasMutex, portMAX_DELAY);

    // --- PHÁT HIỆN CHÁY ---
    if (gasCount >= 5 && !gasDetected) {
      gasDetected = true;
      gasEmergency = true;
      Serial.println(">>> EMERGENCY: GAS DETECTED! STOPPING ALL OTHER TASKS! <<<");
      
      if (fallTaskHandle != NULL) vTaskSuspend(fallTaskHandle);
      if (doorTaskHandle != NULL) vTaskSuspend(doorTaskHandle);
      if (telegramTaskHandle != NULL) vTaskSuspend(telegramTaskHandle);
      
      digitalWrite(BUZZER_PIN, HIGH);
      digitalWrite(LED_PIN, HIGH);
      myServo.write(90);
      
      if (!gasSent) {
        sendTelegram("WARNING: GAS DETECTED! SYSTEM LOCKDOWN! Door Opened.");
        gasSent = true;
      }
    }

    // --- HẾT CHÁY ---
    if (clearCount >= 5 && gasDetected) {
      gasDetected = false;
      gasEmergency = false;
      Serial.println(">>> AIR SAFE: RESUMING SYSTEM <<<");
      
      digitalWrite(BUZZER_PIN, LOW);
      digitalWrite(LED_PIN, LOW);
      ledOn = false;
      myServo.write(0);
      
      if (telegramTaskHandle != NULL) vTaskResume(telegramTaskHandle);
      if (doorTaskHandle != NULL) vTaskResume(doorTaskHandle);
      if (fallTaskHandle != NULL) vTaskResume(fallTaskHandle);
      
      sendTelegram("Air is safe. System resumed. Door closed.");
      gasSent = false;
    }

    xSemaphoreGive(gasMutex);
    
    if (gasDetected) {
      myServo.write(90);
      digitalWrite(LED_PIN, HIGH);
    }
    
    vTaskDelay(pdMS_TO_TICKS(100));
  }
}

// TASK 2: FALL DETECTION (SỬA LỖI DOUBLE TRIGGER)
void fallTask(void *pvParameters) {
  unsigned long lastMotionTime = 0;
  bool alert10sTriggered = false;
  bool alert15sActive = false;
  bool telegramSent = false;
  bool wasRD03Active = false;

  Serial.println("TASK FALL: Running");

  while (1) {
    int pir = digitalRead(PIR_ALERT_PIN);
    int rd03 = digitalRead(RD03_PIN);

    // --- PHẦN 1: ĐÈN & CHUYỂN ĐỘNG ---
    if (pir == HIGH) {
       if (!ledOn) {
         digitalWrite(LED_PIN, HIGH);
         ledOn = true;
         Serial.println("Motion: LED ON");
       }
       lastMotionTime = millis();
       
       if (alert10sTriggered || alert15sActive) {
         Serial.println("Motion detected! Alerts cleared.");
         digitalWrite(BUZZER_PIN, LOW);
         alert10sTriggered = false;
         alert15sActive = false;
         telegramSent = false;
       }
    } 
    else if (pir == LOW && rd03 == LOW) {
       if (ledOn) {
         digitalWrite(LED_PIN, LOW);
         ledOn = false;
       }
    }

    // --- PHẦN 2: CẢNH BÁO NGÃ ---
    if (rd03 == LOW) {
      if (wasRD03Active) {
        wasRD03Active = false;
        alert10sTriggered = false;
        alert15sActive = false;
        telegramSent = false;
        digitalWrite(BUZZER_PIN, LOW);
        
        // --- SỬA LỖI Ở ĐÂY ---
        // Khi không có người (RD03 LOW), phải reset bộ đếm thời gian
        // để tránh trường hợp RD03 nhiễu làm bộ đếm vẫn giữ giá trị cũ > 10000
        lastMotionTime = 0; 
      }
    }
    else { // RD03 HIGH
      if (!wasRD03Active) {
        wasRD03Active = true;
        if (lastMotionTime == 0) lastMotionTime = millis();
      }

      if (pir == LOW && lastMotionTime > 0) {
         unsigned long noMotionDuration = millis() - lastMotionTime;

         // Cảnh báo 10s
         if (noMotionDuration >= 10000 && !alert10sTriggered) {
           alert10sTriggered = true; // SỬA LỖI: Đặt cờ ngay lập tức để tránh lặp
           
           Serial.println("CẢNH BÁO: 10s KHÔNG CHUYỂN ĐỘNG");
           for (int i = 0; i < 2; i++) {
             digitalWrite(LED_PIN, HIGH); digitalWrite(BUZZER_PIN, HIGH);
             vTaskDelay(pdMS_TO_TICKS(200));
             digitalWrite(LED_PIN, LOW); digitalWrite(BUZZER_PIN, LOW);
             vTaskDelay(pdMS_TO_TICKS(200));
           }
           if (ledOn) digitalWrite(LED_PIN, HIGH);
         }

         // Cảnh báo 15s
         if (noMotionDuration >= 15000) {
           if (!alert15sActive) alert15sActive = true;
           if (!telegramSent) {
             sendTelegram("KHẨN CẤP: CÓ NGƯỜI NGÃ!!!!!!!");
             telegramSent = true;
           }
           digitalWrite(LED_PIN, HIGH); digitalWrite(BUZZER_PIN, HIGH);
           vTaskDelay(pdMS_TO_TICKS(500));
           digitalWrite(LED_PIN, LOW); digitalWrite(BUZZER_PIN, LOW);
           vTaskDelay(pdMS_TO_TICKS(500));
           continue; 
         }
      }
    }
    vTaskDelay(pdMS_TO_TICKS(50));
  }
}

// TASK 3: DOOR CONTROL
void doorTask(void *pvParameters) {
  bool open = false;
  Serial.println("TASK DOOR: Running");

  while (1) {
    if (manualOpen) {
      unsigned long elapsed = millis() - manualOpenTimer;
      if (elapsed < 5000) {
        if (!open) { myServo.write(90); open = true; }
      } else {
        if (open) { myServo.write(0); open = false; }
        manualOpen = false;
      }
      vTaskDelay(pdMS_TO_TICKS(100));
      continue;
    }
    
    if (manualClose) {
      if (open) { myServo.write(0); open = false; }
      vTaskDelay(pdMS_TO_TICKS(500));
      continue;
    }
    
    long distance = getDistance();
    if (distance > 2 && distance < 400) {
      if (distance <= DISTANCE_THRESHOLD && !open) {
        myServo.write(90); open = true;
      }
      if (distance > DISTANCE_THRESHOLD && open) {
        myServo.write(0); open = false;
      }
    }
    vTaskDelay(pdMS_TO_TICKS(100));
  }
}

// TASK 4: TELEGRAM
void telegramTask(void *pvParameters) {
  Serial.println("TASK TELEGRAM: Running");
  unsigned long lastUpdate = 0;
  long lastUpdateId = 0;

  while (1) {
    if (millis() - lastUpdate < 2000) {
      vTaskDelay(pdMS_TO_TICKS(100));
      continue;
    }
    lastUpdate = millis();

    if (WiFi.status() != WL_CONNECTED) continue;

    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;

    String url = "https://api.telegram.org/bot";
    url += BOT_TOKEN;
    url += "/getUpdates?offset=" + String(lastUpdateId + 1);
    url += "&timeout=1";

    http.begin(client, url);
    http.setTimeout(5000);
    int httpCode = http.GET();

    if (httpCode == 200) {
      String response = http.getString();
      int updateIdPos = response.lastIndexOf("\"update_id\":");
      if (updateIdPos > 0) {
        int idStart = updateIdPos + 12;
        int idEnd = response.indexOf(",", idStart);
        if (idEnd > idStart) lastUpdateId = response.substring(idStart, idEnd).toInt();
      }

      if (response.indexOf("/open") > 0) {
        manualClose = false; manualOpen = true; manualOpenTimer = millis();
        sendTelegram("Door opening (5s)");
      }
      else if (response.indexOf("/close") > 0) {
        manualOpen = false; manualClose = true;
        sendTelegram("Door LOCKED.");
      }
    }
    http.end();
    client.stop();
    vTaskDelay(pdMS_TO_TICKS(100));
  }
}
